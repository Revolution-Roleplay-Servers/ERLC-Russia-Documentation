{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "ER:LC Россия API",
  "colors": {
    "primary": "#02B1DA",
    "light": "#02B1DA",
    "dark": "#02B1DA"
  },
  "icons": {
    "library": "fontawesome"
  },
  "favicon": {
    "light": "/favicon.png",
    "dark": "/favicon.png"
  },
  "navigation": {
    "languages": [
      {
        "$ref": "./ru.json"
      },
      {
        "$ref": "./en.json"
      }
    ]
  },
  "logo": {
    "light": "/icons/Banner-ERLC-Russia-Docs-System.svg",
    "dark": "/icons/Banner-ERLC-Russia-Docs-System.svg"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "background": {
    "color": {
      "dark": "#0A0A0A"
    }
  },
  "appearance": {
    "default": "dark"
  },
  "redirects": [
    {
      "source": "/en/our-discord",
      "destination": "/en",
      "permanent": false
    },
    {
      "source": "/ru/our-discord",
      "destination": "/ru",
      "permanent": false
    },
    {
      "source": "/en/other/our-discord",
      "destination": "/en",
      "permanent": false
    },
    {
      "source": "/ru/other/our-discord",
      "destination": "/ru",
      "permanent": false
    },
    {
      "source": "/en/tutorials/our-discord",
      "destination": "/en",
      "permanent": false
    },
    {
      "source": "/ru/tutorials/our-discord",
      "destination": "/ru",
      "permanent": false
    },
    {
      "source": "/en/docs-features/our-discord",
      "destination": "/en",
      "permanent": false
    },
    {
      "source": "/ru/docs-features/our-discord",
      "destination": "/ru",
      "permanent": false
    }
  ]
}
